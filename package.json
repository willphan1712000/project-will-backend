{
  "name": "@willphan1712000/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willphan1712000/project-will-backend.git"
  },
  "keywords": [
    "typescript",
    "npm",
    "library"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/willphan1712000/project-will-backend/issues"
  },
  "homepage": "https://github.com/willphan1712000/project-will-backend#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.17",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "express": "^5.2.1"
  }
}
